{
  "manifest_version": 3,
  "name": "AudioHD Pro",
  "version": "1.0.0",
  "description": "Premium browser audio enhancement - 10-Band EQ, Spatial Audio, Volume Booster, HD Crystalizer & more.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["audio/audio-engine.js", "content/content-script.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "AudioHD Pro"
  },
  "options_page": "options/options.html",
  "web_accessible_resources": [
    {
      "resources": ["audio/worklet-processor.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
